\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{surfacecode1}[2024/05/20 Surface Code TikZ Package]

\RequirePackage{tikz}
\RequirePackage{xcolor}
\usetikzlibrary{calc}

% ==========================================
% SURFACE CODE COLORS
% ==========================================
\definecolor{scgray}{RGB}{180,180,180}        % interior face A — medium gray
\definecolor{scdarkgray}{RGB}{255,255,255}    % interior face B — white
\definecolor{scpink}{RGB}{255,255,255}        % default boundary face — white
\definecolor{scblue}{RGB}{180,180,180}        % boundary face (alt) — medium gray
\definecolor{scgreenhighlight}{RGB}{102,204,153}
\definecolor{scpinkhighlight}{RGB}{255,153,204}

% ==========================================
% LAYERING SYSTEM
% ==========================================
\pgfdeclarelayer{scback}
\pgfdeclarelayer{scmid}
\pgfdeclarelayer{scfront}
\pgfdeclarelayer{scmwpm}
\pgfsetlayers{scback,scmid,scmwpm,scfront,main}

\newif\ifscvirtual
\scvirtualfalse

% ==========================================
% GLOBAL DIM — needed by \scface outside \scgrid
% ==========================================
% \scDim is set globally by \scgrid so that \scface boundary
% checks work even when \scface is called independently after
% \scgrid has run.
\newcommand{\scDim}{5}   % sensible default; overwritten by \scgrid

% ==========================================
% 3D SPACE-TIME SETUPS
% ==========================================
\tikzset{
    scisometric/.style={
        x={(0.866cm, -0.5cm)},
        y={(0.866cm, 0.5cm)}
    }
}

\newcommand{\scLayerSeparation}{3.5cm}

\newenvironment{sclayer}[1]{
    \begin{scope}[yshift=#1 * \scLayerSeparation]
}{
    \end{scope}
}

% ==========================================
% CORE COMMANDS
% ==========================================

% \scgrid[N] — draw an N×N surface-code grid (default 5)
\newcommand{\scgrid}[1][5]{
    \pgfmathtruncatemacro{\scDimLocal}{#1}%
    \pgfmathtruncatemacro{\scMaxLocal}{\scDimLocal-1}%
    % Expose \scDim globally so \scface boundary checks work
    \global\edef\scDim{\scDimLocal}%

    % Interior faces (checkerboard colouring)
    \foreach \i in {1,...,\scMaxLocal}{%
        \foreach \j in {1,...,\scMaxLocal}{%
            \pgfmathparse{int(mod(\i+\j,2))}%
            \ifnum\pgfmathresult=0\relax
                \scface[fill=scgray]{\i}{\j}{}%
            \else
                \scface[fill=scdarkgray]{\i}{\j}{}%
            \fi
        }%
    }%

    % Boundary faces — FIX: was using ] instead of } on the last \scface call
    \foreach \k in {1,...,\scMaxLocal}{%
        \pgfmathparse{int(mod(\k,2))}%
        \ifnum\pgfmathresult=1\relax
            \scface[fill=scblue]{\k}{0}{}%
            \scface[fill=scblue]{\k}{\scDim}{}%
        \else
            \scface[fill=scpink]{0}{\k}{}%
            \scface[fill=scpink]{\scDim}{\k}{}%  % FIX: was \scface[fill=scpink}{\scDim}{\k}{}
        \fi
    }%

    % Grid lines — kept in scback so they are always behind faces AND nodes
    \begin{pgfonlayer}{scback}
        \draw[thick] (1,1) grid (\scDim,\scDim);
    \end{pgfonlayer}

    % Data qubits
    \foreach \i in {1,...,\scDim}{%
        \foreach \j in {1,...,\scDim}{%
            \scnode{\i}{\j}{}%
        }%
    }%
}

% \scface[style]{x}{y}{label}
% Draws one stabiliser face; handles interior and the four boundary cases.
% Boundary detection compares against the global \scDim.
\newcommand{\scface}[4][fill=scpink]{%
    \begin{pgfonlayer}{scback}
        % FIX: added \relax after every \scDim comparison so TeX does not
        %      try to absorb following tokens into the number being compared.
        \ifnum#2=0\relax
            \ifscvirtual
                \fill[#1] (0, #3) rectangle (1, #3+1);
            \else
                \fill[#1] (1, #3+1) arc (90:270:0.5) -- cycle;
            \fi
            \node at (0.5, #3+0.5) {#4};
        \else\ifnum#2=\scDim\relax
            \ifscvirtual
                \fill[#1] (\scDim, #3) rectangle (\scDim+1, #3+1);
            \else
                \fill[#1] (\scDim, #3) arc (-90:90:0.5) -- cycle;
            \fi
            \node at (\scDim+0.5, #3+0.5) {#4};
        \else\ifnum#3=0\relax
            \ifscvirtual
                \fill[#1] (#2, 0) rectangle (#2+1, 1);
            \else
                \fill[#1] (#2, 1) arc (180:360:0.5) -- cycle;
            \fi
            \node at (#2+0.5, 0.5) {#4};
        \else\ifnum#3=\scDim\relax
            \ifscvirtual
                \fill[#1] (#2, \scDim) rectangle (#2+1, \scDim+1);
            \else
                \fill[#1] (#2+1, \scDim) arc (0:180:0.5) -- cycle;
            \fi
            \node at (#2+0.5, \scDim+0.5) {#4};
        \else
            \fill[#1] (#2, #3) rectangle (#2+1, #3+1);
            \node at (#2+0.5, #3+0.5) {#4};
        \fi\fi\fi\fi
    \end{pgfonlayer}%
}

% \scnode[style]{x}{y}{label}
% Circle drawn in scfront (above grid lines in scmid and faces in scback).
% Label drawn as bare text in main (topmost) with a white background to
% cleanly mask whatever sits behind it — no border, no box.
\newcommand{\scnode}[4][fill=white, draw=black, thick]{%
    \begin{pgfonlayer}{scfront}
        \filldraw[#1] (#2,#3) circle (0.15);
    \end{pgfonlayer}%
    \begin{pgfonlayer}{main}
        \node[font=\scriptsize, fill=white, inner sep=1pt,
              draw=none, text depth=0pt] at (#2,#3) {#4};
    \end{pgfonlayer}%
}

% \scedge[style]{x1}{y1}{x2}{y2}{label}
% The line goes into scmid so it is always painted BEFORE node circles
% (scfront) and labels (main). The label is bare text with a white fill
% to erase the line behind it — no circle, no border.
\newcommand{\scedge}[6][very thick]{%
    \begin{pgfonlayer}{scmid}
        \draw[#1] (#2, #3) -- (#4, #5);
    \end{pgfonlayer}%
    \if\relax\detokenize{#6}\relax\else
        \begin{pgfonlayer}{main}
            \node[fill=white, inner sep=1.5pt, draw=none, font=\scriptsize]
                at ($(#2,#3)!0.5!(#4,#5)$) {#6};
        \end{pgfonlayer}%
    \fi
}

% ==========================================
% MWPM (MINIMUM-WEIGHT PERFECT MATCHING) HELPERS
% ==========================================

% \scmwpmnode[style]{col}{row}   — syndrome dot at face centre
\newcommand{\scmwpmnode}[3][fill=black]{%
    \begin{pgfonlayer}{scfront}
        \fill[#1] (#2+0.5, #3+0.5) circle (0.08);
    \end{pgfonlayer}%
}

% \scmwpmedge[style]{c1}{r1}{c2}{r2}  — matching edge (2-D)
\newcommand{\scmwpmedge}[5][thick]{%
    \begin{pgfonlayer}{scmwpm}
        \draw[#1] (#2+0.5, #3+0.5) -- (#4+0.5, #5+0.5);
    \end{pgfonlayer}%
}

% \scmwpmedge3D[style]{c1}{r1}{layer1}{c2}{r2}{layer2}  — matching edge (3-D)
\newcommand{\scmwpmedge3D}[7][thick]{%
    \begin{pgfonlayer}{scmwpm}
        \draw[#1]
            ($ (#2+0.5, #3+0.5) + (0, #4 * \scLayerSeparation) $) --
            ($ (#5+0.5, #6+0.5) + (0, #7 * \scLayerSeparation) $);
    \end{pgfonlayer}%
}

% \scmwpmnode3D[style]{col}{row}{layer}  — syndrome dot (3-D)
\newcommand{\scmwpmnode3D}[4][fill=black]{%
    \begin{pgfonlayer}{scfront}
        \fill[#1] ($ (#2+0.5, #3+0.5) + (0, #4 * \scLayerSeparation) $) circle (0.08);
    \end{pgfonlayer}%
}
